<%
var bodyContent = `
<div class="transfer-page">

    <h1 class='page-title'>Transfer Money</h1>
    <p class='page-subtitle'>Send money to your own accounts or others</p>

    <!-- Tabs: Local vs Overseas only -->
    <div class='transfer-tabs'>
        <button class='tab active' data-mode="local">Local Transfer</button>
        <button class='tab' data-mode="overseas">Overseas Transfer</button>
    </div>

    <div class='card transfer-card'>

        <div class='transfer-header'>
            <div class='icon-circle'><span>↻</span></div>
            <div>
                <h2>Transfer Between Accounts</h2>
                <p class='muted'>Instant and free</p>
            </div>
        </div>

        ${error ? `<div class="alert alert-error">${error}</div>` : ""}
        ${success ? `<div class="alert alert-success" style="background:#ecfdf5;border:1px solid #6ee7b7;color:#065f46;">${success}</div>` : ""}

        <form action="/transfer" method="POST" class="form">

            <label>From Account</label>
            <select name="from" class="input-select" required>
                <option value="">Select account</option>
                <option value="${user.account_number}">
                    ${user.account_type} — **** ${String(user.account_number).slice(-4)}
                </option>
            </select>

            <label>To Account</label>
            <input type="text" name="recipient" class="input" placeholder="Enter account number" required>

            <label>Amount</label>
            <input type="number" name="amount" class="input" step="0.01" required>

            <label>Remarks (Optional)</label>
            <input type="text" name="remarks" class="input" placeholder="Add a note">

            <!-- Extra fields for OVERSEAS transfers -->
            <div class="overseas-fields" style="display:none; margin-top:8px;">
                <label>Destination Country</label>
                <select class="input-select" name="country">
                    <option value="MY">Malaysia</option>
                    <option value="ID">Indonesia</option>
                    <option value="CN">China</option>
                    <option value="TH">Thailand</option>
                </select>

                <label>Currency</label>
                <select class="input-select" name="currency">
                    <option value="MYR">MYR – Malaysian Ringgit</option>
                    <option value="IDR">IDR – Indonesian Rupiah</option>
                    <option value="CNY">CNY – Chinese Yuan</option>
                    <option value="THB">THB – Thai Baht</option>
                </select>
            </div>

            <div class='transfer-buttons'>
                <button type="submit" class="button red full">Transfer Now</button>
                <button type="button" class="button outline full">Schedule Transfer</button>
            </div>

        </form>

    </div>

    <div class='card recent-transfers'>
        <h3 class='recent-header'><span>⏱</span> Recent Transfers</h3>

        <div class='transfer-list'>

            <div class='transfer-item'>
                <div>
                    <p class='name'>John Doe</p>
                    <p class='muted'>**** 1234</p>
                </div>
                <div class='amount-col'>
                    <p class='amount'>SGD 500.00</p>
                    <p class='muted small'>Oct 30</p>
                </div>
            </div>

            <div class='transfer-item'>
                <div>
                    <p class='name'>Jane Smith</p>
                    <p class='muted'>**** 5678</p>
                </div>
                <div class='amount-col'>
                    <p class='amount'>SGD 250.00</p>
                    <p class='muted small'>Oct 28</p>
                </div>
            </div>

            <div class='transfer-item'>
                <div>
                    <p class='name'>Michael Chen</p>
                    <p class='muted'>**** 9012</p>
                </div>
                <div class='amount-col'>
                    <p class='amount'>SGD 1000.00</p>
                    <p class='muted small'>Oct 25</p>
                </div>
            </div>

        </div>
    </div>

</div>

<button id="tutorial-btn" class="tutorial-button">🧭 Tutorial</button>

<script>
document.addEventListener('DOMContentLoaded', function () {
    var tabs = document.querySelectorAll('.transfer-tabs .tab');
    var overseasFields = document.querySelector('.overseas-fields');

    if (!tabs.length || !overseasFields) return;

    tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
            tabs.forEach(function (t) { t.classList.remove('active'); });
            this.classList.add('active');

            var mode = this.getAttribute('data-mode');
            if (mode === 'overseas') {
                overseasFields.style.display = 'block';
            } else {
                overseasFields.style.display = 'none';
            }
        });
    });
});
</script>
`;
%>

<%- include("layout", { title: "Transfer Money", body: bodyContent, user: user, error: error, success: success }) %>
