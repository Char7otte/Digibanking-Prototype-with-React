<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || "OCBC Digital" %></title>

    <link rel="stylesheet" href="/css/bootstrap.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/tutorial.css">

    <script defer src="/js/main.js"></script>
    <script defer src="/js/tutorial.js"></script>
</head>

<body>

    <%- include('partials/header', { user: user }) %>

    <main class="page-container">
        <%- body %>
    </main>

    <!-- Accessibility (now on ALL pages) -->
    <%- include('partials/accessibilityComponent.ejs') %>

    <!-- Tutorial Modal System -->
    <div id="tutorial-overlay" class="hidden"></div>

    <div id="tutorial-modal" class="hidden">
        <div class="tutorial-content">
            <h3>What do you want to learn?</h3>

            <button class="tutorial-option" data-tutorial="transfer">💸 How to transfer money</button>
            <button class="tutorial-option" data-tutorial="profile">👤 How to edit your profile</button>
            <button class="tutorial-option" data-tutorial="paybills">🧾 How to pay bills</button>

            <button class="tutorial-close">❌ Close</button>
        </div>
    </div>

    <div id="tutorial-highlight" class="hidden"></div>
    <div id="tutorial-step-box" class="hidden"></div>

</body>
</html>
