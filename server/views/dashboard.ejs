<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
    <title><%= title %></title>
</head>
<body>

    <%- include("partials/header", { user: user }) %>

    <main class="page-container">
        <section class="dashboard">

            <div class="dashboard-header">
                <div>
                    <p class="label">Welcome back</p>
                    <h2 class="user-name"><%= name %></h2>
                </div>

                <div class="dashboard-total">
                    <p class="label">Total balance</p>
                    <p class="amount">
                        <%= currency %> <%= Number(balance || 0).toFixed(2) %>
                    </p>
                </div>
            </div>

            <div class="grid grid-2">
                <div class="card account-summary">
                    <h3>Your account</h3>

                    <%- include("partials/accountCardComponent.ejs", {
                        account_type: account_type,
                        account_number: accountNumber,
                        balance: balance,
                        currency: currency
                    }) %>
                </div>

                <div class="card quick-actions">
                    <h3>Quick actions</h3>
                    <div class="quick-actions-grid">
                        <a href="/transfer" class="quick-action">Transfer</a>
                        <a href="/profile" class="quick-action">Profile</a>
                    </div>
                </div>
            </div>

        </section>
    </main>

    <%- include("partials/accessibilityComponent.ejs") %>
    <%- include("partials/footer") %>

</body>
</html>
